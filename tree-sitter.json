{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "dart",
      "camelcase": "Dart",
      "title": "Dart",
      "scope": "source.dart",
      "file-types": [
        "dart"
      ],
      "injection-regex": "^dart$",
      "class-name": "TreeSitterDart",
      "highlights": "queries/highlights.scm",
      "tags": "queries/tags.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Dart grammar for tree-sitter",
    "authors": [
      {
        "name": "Kasper Overgård Nielsen",
        "email": "kasper@byolimit.com"
      }
    ],
    "links": {
      "repository": "https://github.com/nielsenko/tree-sitter-dart"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}